# --- FPL league basics ---
FPL_DRAFT_LEAGUE_ID=
FPL_DRAFT_TEAM_ID=

# Classic FPL - comma-separated league IDs with optional names
# Format: id:name,id:name,... (name is optional, will be fetched from API if omitted)
# Examples:
#   FPL_CLASSIC_LEAGUE_IDS=123456:Work League,789012:Friends League
#   FPL_CLASSIC_LEAGUE_IDS=123456,789012
FPL_CLASSIC_LEAGUE_IDS=
FPL_CLASSIC_TEAM_ID=

# --- Notifications ---
DISCORD_WEBHOOK_URL=
DISCORD_MENTION_USER_ID=
DISCORD_MENTION_ROLE_ID=

# --- Deadline Alerts (both disabled by default - set to true to enable) ---
# Draft alerts (waiver/transaction deadline is 25.5h before kickoff)
FPL_DRAFT_ALERTS_ENABLED=false
FPL_DEADLINE_OFFSET_HOURS=25.5

# Classic alerts (transfer deadline is 1.5h before kickoff)
FPL_CLASSIC_ALERTS_ENABLED=false
FPL_CLASSIC_DEADLINE_OFFSET_HOURS=1.5

# --- External APIs ---
# The Odds API (https://the-odds-api.com) - for match betting odds
ODDS_API_KEY=

# --- App Settings ---
TZ_NAME=America/New_York

# --- Season Wrapped: Past Draft league IDs for cross-season history ---
# Format: YYYY/YY:league_id,YYYY/YY:league_id (comma-separated, sorted by season)
# Add each completed season's league ID here to enable multi-season history.
# The current season is always included automatically via FPL_DRAFT_LEAGUE_ID.
# Example: FPL_DRAFT_LEAGUE_HISTORY=2023/24:123456,2024/25:789012
FPL_DRAFT_LEAGUE_HISTORY=